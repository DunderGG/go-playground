@startuml GoDoxy Flow
actor User
participant "main()" as CLI
participant "File System" as FS
participant "Lexical Parser" as Parser
participant "Metadata Extractor" as Meta
participant "Markdown/HTML Generator" as Generator
participant "Search Index Generator" as Search

User -> CLI : Run GoDoxy (-source <path> -out <path> -format <md|html>)

alt Missing or invalid arguments
    CLI --> User : Error: missing required flags\n(print usage and exit)
end

CLI -> FS : Verify output directory exists\n(create if missing)

alt Output directory cannot be created
    CLI --> User : Error: cannot create output dir\n(exit with code 1)
end

CLI -> FS : Scan for .h Files
FS --> CLI : List of Header Files

alt No .h files found
    CLI --> User : Warning: no header files found at source path\n(exit early)
end

loop For each Header File
    CLI -> FS : Read File Content

    alt File unreadable (permissions / bad encoding)
        FS --> CLI : Error
        CLI -> CLI : Log warning, skip file
    else File OK
        FS --> CLI : Raw C++ String
        CLI -> Parser : Tokenize Content
        Parser -> Parser : Identify Unreal Macros\n(UCLASS, UFUNCTION, UPROPERTY, USTRUCT, UENUM)
        Parser -> Parser : Associate preceding comment block\n(same-block rule: no blank line gap)

        alt Malformed or unclosed macro
            Parser --> CLI : ParseError (file, line, reason)
            CLI -> CLI : Log warning, skip macro
        else Tokens OK
            Parser --> CLI : List of Identified Tokens & Tags
            CLI -> Meta : Extract Signatures & Comments
            Meta --> CLI : Structured Metadata\n(Params, Returns, Specifiers, ToolTip)
        end
    end
end

CLI -> CLI : Build Dependency/Cross-Ref Map\n(map type name -> output file path)

loop For each Class/Struct/Enum
    CLI -> Generator : Render Documentation\n(Templates + Cross-Ref Map)

    alt Output file write fails
        Generator --> CLI : Error
        CLI -> CLI : Log warning, continue
    else Write OK
        Generator -> FS : Write .md or .html File
    end
end

CLI -> Search : Generate Search Index\n(pass all DocumentedType entries)
Search -> FS : Save search_index.json

alt Any warnings were logged
    CLI --> User : Done with warnings — see godoxygo.log
else All clean
    CLI --> User : Documentation successfully generated!
end
@enduml
